# Database
DATABASE_URL=postgresql+asyncpg://operyx:operyx@localhost:5432/operyx
DATABASE_URL_SYNC=postgresql://operyx:operyx@localhost:5432/operyx

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads

# Providers — mock works out of the box; set for real inference
STT_PROVIDER=mock
LLM_PROVIDER=mock

# App
TENANT_ID=default
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8000
